# AEGIS HSSE Platform — Environment Variables
# Copy to .env and fill in. Production secrets MUST be ≥24 chars and not contain
# placeholder words like "dummy", "change", "secret", "password", "123".

# ─── Core ───────────────────────────────────────────────
NODE_ENV="development"
# Dev: SQLite. Production: PostgreSQL ("postgresql://user:pass@host:5432/db?sslmode=require")
DATABASE_URL="file:./prisma/dev.db"

# Generate via: openssl rand -base64 48
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-48"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI providers ───────────────────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-5-20250929"

# Optional: Google Gemini for video / vision
GEMINI_API_KEY=""

# ─── Notifications ──────────────────────────────────────
# Optional: WhatsApp via CallMeBot (https://www.callmebot.com/)
CALLMEBOT_PHONE=""
CALLMEBOT_APIKEY=""

# ─── Autonomy & devices ─────────────────────────────────
# Generate via: openssl rand -hex 32
# Required for /api/autonomy/pipeline/tick and /api/compliance/retention from cron
CRON_SECRET=""

# Generate via: openssl rand -base64 32
# Encrypts PII fields at rest (phone numbers, etc). Falls back to NEXTAUTH_SECRET if unset.
# CRITICAL: never rotate without re-encrypting existing data
ENCRYPTION_KEY=""

# Generate via: openssl rand -hex 32
# HMAC key for the tamper-evident audit log chain. Falls back to NEXTAUTH_SECRET.
# CRITICAL: must be backed up off-site for true integrity
AUDIT_CHAIN_SECRET=""

# Optional: override password policy minimum length (default 12)
# PASSWORD_MIN_LEN="12"

# Production: disables /api/auth/demo-setup endpoint
# DISABLE_DEMO_SETUP="1"

# Required to scrape /api/metrics in production
METRICS_TOKEN=""

# Required for ESP32 wearables posting to /api/wellness/ingest
DEVICE_INGEST_SECRET=""

# ─── Observability ──────────────────────────────────────
# debug / info / warn / error / fatal (default: info in prod, debug in dev)
LOG_LEVEL="debug"
# Optional: Sentry DSN for error tracking
SENTRY_DSN=""

# ─── PPE Monitor (legacy) ───────────────────────────────
PPE_MONITOR_URL=""

# ─── Seed defaults ──────────────────────────────────────
SEED_ADMIN_EMAIL="turki@aegis.local"
SEED_ADMIN_PASSWORD="123"

# ─── Branding ───────────────────────────────────────────
APP_NAME="AEGIS"
APP_TAGLINE="HSSE Command Platform"
