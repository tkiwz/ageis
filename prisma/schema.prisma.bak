// AEGIS HSSE Platform — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════ IDENTITY & AUDIT ═══════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OPERATOR")
  department   String?
  phone        String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions             Session[]
  reportedIncidents    Incident[]            @relation("IncidentReporter")
  assignedIncidents    Incident[]            @relation("IncidentAssignee")
  requestedPermits     Permit[]              @relation("PermitRequester")
  approvedPermits      Permit[]              @relation("PermitApprover")
  assignedTasks        Task[]
  enrollments          TrainingEnrollment[]
  conductedInspections Inspection[]
  riskAssessments      RiskAssessment[]
  responsibleCompliance ComplianceItem[]
  uploadedDocuments    Document[]
  observations         Observation[]
  investigations       Investigation[]
  commandedEmergencies EmergencyEvent[]
  auditLogs            AuditLog[]

  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model AuditLog {
  id           String   @id @default(cuid())
  module       String
  action       String
  actionType   String   @default("MANUAL")
  isAutonomous Boolean  @default(false)
  description  String
  metadata     String?
  riskLevel    String?
  userId       String?
  siteId       String?
  createdAt    DateTime @default(now())
  user User? @relation(fields: [userId], references: [id])
  site Site? @relation(fields: [siteId], references: [id])
  @@index([module, createdAt])
  @@index([isAutonomous])
}

// ═══════ SITES ═══════

model Site {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  nameAr           String?
  description      String?
  productionType   String   @default("OIL_AND_GAS")
  status           String   @default("ACTIVE")
  riskLevel        String   @default("LOW")
  latitude         Float
  longitude        Float
  capacity         Int      @default(0)
  currentOccupancy Int      @default(0)
  isLockedDown     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  incidents         Incident[]
  permits           Permit[]
  devices           IoTDevice[]
  riskAssessments   RiskAssessment[]
  weatherReadings   WeatherReading[]
  emissionReadings  EmissionReading[]
  complianceItems   ComplianceItem[]
  inspections       Inspection[]
  tasks             Task[]
  emergencyEvents   EmergencyEvent[]
  documents         Document[]
  alerts            Alert[]
  observations      Observation[]
  auditLogs         AuditLog[]

  @@index([status])
  @@index([riskLevel])
}

// ═══════ OPERATIONS ═══════

model Permit {
  id              String   @id @default(cuid())
  permitNumber    String   @unique
  title           String
  type            String
  status          String   @default("DRAFT")
  riskLevel       String   @default("MEDIUM")
  description     String?
  location        String
  validFrom       DateTime
  validUntil      DateTime
  isAutoApproved  Boolean  @default(false)
  isAutoRevoked   Boolean  @default(false)
  revocationReason String?
  siteId        String
  requesterId   String
  approverId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  site       Site            @relation(fields: [siteId], references: [id])
  requester  User            @relation("PermitRequester", fields: [requesterId], references: [id])
  approver   User?           @relation("PermitApprover", fields: [approverId], references: [id])
  conditions PermitCondition[]
  @@index([status])
  @@index([type])
}

model PermitCondition {
  id          String   @id @default(cuid())
  permitId    String
  description String
  isMandatory Boolean  @default(true)
  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?
  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  priority    String   @default("MEDIUM")
  status      String   @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  isAutoAssigned Boolean @default(false)
  siteId     String?
  assigneeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  site     Site? @relation(fields: [siteId], references: [id])
  assignee User? @relation(fields: [assigneeId], references: [id])
  @@index([status, priority])
}

model IoTDevice {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  type         String
  status       String   @default("ONLINE")
  location     String?
  unit         String
  warningHigh  Float?
  criticalHigh Float?
  warningLow   Float?
  criticalLow  Float?
  lastReadingAt DateTime?
  siteId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site     Site            @relation(fields: [siteId], references: [id])
  readings SensorReading[]
  @@index([type, status])
}

model SensorReading {
  id         String   @id @default(cuid())
  deviceId   String
  value      Float
  isAnomaly  Boolean  @default(false)
  alertLevel String?
  recordedAt DateTime @default(now())
  device IoTDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  @@index([deviceId, recordedAt])
}

// ═══════ SAFETY ═══════

model Incident {
  id              String   @id @default(cuid())
  incidentNumber  String   @unique
  title           String
  description     String
  type            String
  severity        String   @default("LOW")
  status          String   @default("REPORTED")
  location        String
  occurredAt      DateTime
  reportedAt      DateTime @default(now())
  resolvedAt      DateTime?
  isAutoEscalated Boolean  @default(false)
  aiAnalysis      String?
  siteId       String
  reporterId   String
  assigneeId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  site         Site            @relation(fields: [siteId], references: [id])
  reporter     User            @relation("IncidentReporter", fields: [reporterId], references: [id])
  assignee     User?           @relation("IncidentAssignee", fields: [assigneeId], references: [id])
  actions      IncidentAction[]
  investigation Investigation?
  @@index([status, severity])
}

model IncidentAction {
  id          String   @id @default(cuid())
  incidentId  String
  description String
  status      String   @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  isAutoGenerated Boolean @default(false)
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model Observation {
  id              String   @id @default(cuid())
  recordNumber    String   @unique
  type            String
  status          String   @default("DRAFT")
  location        String
  findings        String
  unsafeDetail    String?
  reviewerComment String?
  contractor      String?
  observedAt      DateTime @default(now())
  siteId       String
  reportedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  site       Site @relation(fields: [siteId], references: [id])
  reportedBy User @relation(fields: [reportedById], references: [id])
  @@index([type, status])
}

model RiskAssessment {
  id                String   @id @default(cuid())
  title             String
  type              String
  hazardDescription String
  riskBefore        String
  controlsSuggested String
  riskAfter         String
  aiSuggested       Boolean  @default(false)
  status            String   @default("DRAFT")
  siteId       String
  conductedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  site        Site @relation(fields: [siteId], references: [id])
  conductedBy User @relation(fields: [conductedById], references: [id])
  @@index([type, status])
}

model Investigation {
  id           String   @id @default(cuid())
  incidentId   String   @unique
  rootCause    String?
  summary      String?
  status       String   @default("OPEN")
  hasAIEvidence Boolean @default(false)
  leadInvestigatorId String
  incident         Incident @relation(fields: [incidentId], references: [id])
  leadInvestigator User     @relation(fields: [leadInvestigatorId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ═══════ GOVERNANCE ═══════

model ComplianceItem {
  id                  String   @id @default(cuid())
  title               String
  regulationRef       String
  status              String   @default("PENDING")
  dueDate             DateTime
  isAutoEscalated     Boolean  @default(false)
  triggersLockdown    Boolean  @default(false)
  siteId         String
  responsibleId  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  site        Site @relation(fields: [siteId], references: [id])
  responsible User @relation(fields: [responsibleId], references: [id])
  @@index([status, dueDate])
}

model Contractor {
  id              String   @id @default(cuid())
  name            String
  companyName     String
  contactEmail    String
  contactPhone    String?
  safetyRating    Float    @default(0)
  status          String   @default("ACTIVE")
  isAutoSuspended Boolean  @default(false)
  contractStart   DateTime
  contractEnd     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status])
}

model Inspection {
  id          String   @id @default(cuid())
  title       String
  type        String
  status      String   @default("SCHEDULED")
  fraudDetected Boolean @default(false)
  fraudReason String?
  conductedAt DateTime?
  notes       String?
  siteId        String
  conductedById String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  site        Site @relation(fields: [siteId], references: [id])
  conductedBy User @relation(fields: [conductedById], references: [id])
  @@index([status])
}

model Document {
  id           String   @id @default(cuid())
  title        String
  category     String
  status       String   @default("DRAFT")
  fileUrl      String?
  version      String   @default("1.0")
  requiresAcknowledgment Boolean @default(false)
  siteId       String?
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  site             Site?                  @relation(fields: [siteId], references: [id])
  uploadedBy       User                   @relation(fields: [uploadedById], references: [id])
  acknowledgments  DocumentAcknowledgment[]
}

model DocumentAcknowledgment {
  id             String   @id @default(cuid())
  documentId     String
  userId         String
  acknowledgedAt DateTime @default(now())
  isAccessBlocked Boolean @default(false)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  @@unique([documentId, userId])
}

model Training {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  duration    Int
  validityDays Int     @default(365)
  isMandatory Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id           String   @id @default(cuid())
  trainingId   String
  userId       String
  status       String   @default("ENROLLED")
  completedAt  DateTime?
  expiresAt    DateTime?
  autoEnrolled Boolean  @default(false)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  @@unique([trainingId, userId])
  @@index([status, expiresAt])
}

// ═══════ INTELLIGENCE ═══════

model Rule {
  id            String   @id @default(cuid())
  name          String
  module        String
  description   String?
  severity      String   @default("MEDIUM")
  isActive      Boolean  @default(true)
  conditions    String
  actions       String
  requiresApproval Boolean @default(false)
  triggerCount  Int      @default(0)
  lastTriggeredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  autonomousActions AutonomousAction[]
  @@index([module, isActive])
}

model AutonomousAction {
  id            String   @id @default(cuid())
  ruleId        String?
  actionType    String
  status        String   @default("PENDING")
  description   String
  metadata      String?
  approvedById  String?
  approvedAt    DateTime?
  executedAt    DateTime?
  rejectionReason String?
  rule Rule? @relation(fields: [ruleId], references: [id])
  createdAt DateTime @default(now())
  @@index([status, createdAt])
}

model AIInsight {
  id           String   @id @default(cuid())
  insightType  String
  module       String
  title        String
  content      String
  confidence   Float    @default(0.5)
  metadata     String?
  isActioned   Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([module, createdAt])
}

// ═══════ COMMUNICATION ═══════

model Alert {
  id            String   @id @default(cuid())
  type          String
  title         String
  message       String
  channels      String
  status        String   @default("PENDING")
  isAutonomous  Boolean  @default(false)
  acknowledgedAt DateTime?
  siteId   String?
  createdAt DateTime @default(now())
  site Site? @relation(fields: [siteId], references: [id])
  @@index([type, createdAt])
}

model EmergencyEvent {
  id                   String   @id @default(cuid())
  title                String
  type                 String
  severity             String   @default("MEDIUM")
  status               String   @default("ACTIVE")
  evacuationTriggered  Boolean  @default(false)
  droneDispatched      Boolean  @default(false)
  startedAt            DateTime @default(now())
  resolvedAt           DateTime?
  siteId       String
  commandedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  site         Site @relation(fields: [siteId], references: [id])
  commandedBy  User @relation(fields: [commandedById], references: [id])
  @@index([status, severity])
}

// ═══════ ENVIRONMENT ═══════

model WeatherReading {
  id            String   @id @default(cuid())
  temperature   Float
  humidity      Float
  windSpeed     Float
  windDirection String
  condition     String
  aqi           Int
  alertTriggered Boolean @default(false)
  recordedAt    DateTime @default(now())
  siteId String
  site   Site @relation(fields: [siteId], references: [id])
  @@index([siteId, recordedAt])
}

model EmissionReading {
  id              String   @id @default(cuid())
  co2Level        Float
  noiseLevel      Float
  wasteGenerated  Float
  waterUsage      Float
  bmsAdjusted     Boolean  @default(false)
  recordedAt      DateTime @default(now())
  siteId String
  site   Site @relation(fields: [siteId], references: [id])
  @@index([siteId, recordedAt])
}

// ═══════ FIELD DEVICES (Phase 5A.2) ═══════
// Raspberry Pi vision systems + ESP32 wearable safety devices

model FieldDevice {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  type            String                              // PI_VISION, ESP32_WEARABLE
  ipAddress       String?
  port            Int?
  status          String   @default("OFFLINE")        // ONLINE, OFFLINE, ERROR, MAINTENANCE
  batteryPercent  Int?
  lastSeenAt      DateTime?

  // Pi-specific
  modelClasses    Json?
  modelVersion    String?

  // Counters
  detectionsCount Int      @default(0)
  alertsCount     Int      @default(0)

  // Relations
  siteId    String?
  site      Site?   @relation(fields: [siteId], references: [id])
  workerId  String?
  worker    User?   @relation(fields: [workerId], references: [id])

  visionDetections VisionDetection[]
  telemetry        DeviceTelemetry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([siteId])
}

model VisionDetection {
  id           String   @id @default(cuid())
  deviceId     String
  device       FieldDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  label        String                                  // helmet, no_helmet, oil_leak, mesh_gard, etc
  confidence   Float
  status       String                                  // OK, WARNING, INFO

  allScores    Json?
  imageUrl     String?

  // AI analysis fields
  aiAnalyzed   Boolean  @default(false)
  aiSeverity   String?                                 // LOW, MEDIUM, HIGH, CRITICAL
  aiReasoning  String?
  aiActions    Json?

  alertId      String?

  detectedAt   DateTime @default(now())

  @@index([deviceId, detectedAt])
  @@index([status, aiAnalyzed])
}

model DeviceTelemetry {
  id          String   @id @default(cuid())
  deviceId    String
  device      FieldDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  gasLevel    Float?
  temperature Float?
  pressure    Float?
  acceleration Float?
  voltage     Float?
  currentMa   Float?

  alertActive Boolean  @default(false)
  recordedAt  DateTime @default(now())

  @@index([deviceId, recordedAt])
}

model AIDecision {
  id          String   @id @default(cuid())
  type        String                                   // VISION_ANALYSIS, CHAT, VIDEO_GENERATION
  provider    String                                   // CLAUDE, GEMINI
  modelUsed   String

  inputData   Json
  outputData  Json
  reasoning   String?
  confidence  Float?

  tokensInput  Int?
  tokensOutput Int?
  durationMs   Int?

  autonomous     Boolean @default(false)
  requiresHuman  Boolean @default(false)

  visionDetectionId String?
  telemetryId       String?
  alertId           String?
  incidentId        String?

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([provider])
}
